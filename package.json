{
  "name": "udemy-tts",
  "version": "2.1.1",
  "description": "Reads Udemy lecture subtitles aloud via Edge TTS, with LLM translation",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox --mv3",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile": "wxt prepare && tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "prepare": "wxt prepare",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "edge-tts-universal": "1.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@wxt-dev/i18n": "^0.2.6",
    "@wxt-dev/module-svelte": "^2.0.5",
    "fake-indexeddb": "^6.2.5",
    "patch-package": "^8.0.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
